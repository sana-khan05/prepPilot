# =============================================
# InterviewIQ Backend — Environment Variables
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ---- Server ----
PORT=5000
NODE_ENV=development

# ---- MongoDB ----
# Get free cluster at https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/interviewiq?retryWrites=true&w=majority

# ---- JWT Auth ----
# Use a long random string (min 32 chars)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_also_change_this
JWT_REFRESH_EXPIRES_IN=30d

# ---- File Upload (Cloudinary - free tier) ----
# Sign up at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ---- OpenAI (for Phase 2+) ----
# Get key at https://platform.openai.com
OPENAI_API_KEY=sk-your-openai-key-here

# ---- Email (Nodemailer - for reports) ----
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password

# ---- Frontend URL (for CORS) ----
FRONTEND_URL=http://localhost:5173
